# build mode
NODE_ENV=development

# development server port
SERVE_PORT=8520

# content files
CONTENT_DIR=./src/content/

# template files
TEMPLATE_DIR=./src/template/
TEMPLATE_DEFAULT=default.html
TEMPLATE_LIST=list.html
TEMPLATE_TAG=tag.html

# tags
TAG_ROOT=properties

# CSS and JS browser target
BROWSER_TARGET="chrome140,firefox140,safari17.3"

# build directory
BUILD_DIR=./build/
BUILD_ROOT=/

# CSS entry
CSS_DIR="./src/css/main.css"

# JS entry
JS_DIR="./src/js/main.js"

# site details
SITE_LANGUAGE="en-GB"
SITE_DOMAIN="https://www.exeter-student-lets.co.uk"
SITE_VERSION="1.0.0"
SITE_TITLE="Exeter Student Lets"
SITE_DESCRIPTION="Student accommodation in Exeter, Devon UK."
SITE_AUTHOR="Exeter Student Lets"
SITE_AUTHORURL="https://www.exeter-student-lets.co.uk/"
SITE_AUTHORX="@exeterstudentlets"
SITE_THEMECOLOR="#121b16"
SITE_EMAIL='<a href="mailto:info@exeter-student-lets.co.uk">info@exeter-student-lets.co.uk</a>'
SITE_PHONE='<a href="tel:+44-7740-309-077">+44 7740 309 077</a>'
